{
  "name": "taxia-cimco-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Panel Profesional TaxiA-CIMCO - Sistema Híbrido React + Vite",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "preview": "vite preview",
    "build": "npm run build:css && vite build",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "firebase": "^12.7.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.11.0",
    "sweetalert2": "^11.26.17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
