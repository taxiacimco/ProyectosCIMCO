{
  "name": "taxia-cimco-frontend",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Panel Profesional TaxiA-CIMCO - Sistema Híbrido React + Vite",
  "scripts": {
    "dev": "vite --host",
    "dev:force": "npm run clean:vite && vite --host --force",
    "start": "vite",
    "preview": "vite preview",
    "build": "npm run build:css && vite build",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/output.css --watch",
    "clean": "rimraf dist node_modules/.cache node_modules/.vite",
    "clean:vite": "rimraf node_modules/.vite",
    "tunnel": "ngrok http --domain=globosely-appreciative-zander.ngrok-free.dev 5173",
    "dev:tunnel": "concurrently \"npm run dev\" \"npm run tunnel\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chart.js": "^4.4.1",
    "firebase": "^10.12.0",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.454.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.3.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.0.0",
    "sweetalert2": "^11.14.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}