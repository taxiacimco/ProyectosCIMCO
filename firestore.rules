// Versión Arquitectura: V11.2 - Unificación del Path Sagrado y Gestión de Roles en Bóveda
/**
 * Archivo: firestore.rules
 * Misión: Blindar la estructura de datos de TAXIA CIMCO.
 * Regla de Oro: Toda interacción debe ocurrir bajo artifacts/taxiacimco-app/public/data/
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 💰 SECCIÓN: BILLETERAS (wallets)
     * Máxima seguridad: Solo el CEO (Admin) inyecta saldo.
     * El usuario solo puede consultar su propio estado financiero.
     */
    match /artifacts/taxiacimco-app/public/data/wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    /**
     * 🛵 SECCIÓN: OPERATIVA (viajes, mensajes, conductores)
     * Permite la dinámica del negocio para usuarios autenticados.
     * El comodín {collection} asegura que el Path Sagrado se respete siempre.
     */
    match /artifacts/taxiacimco-app/public/data/{collection}/{document=**} {
      
      // Permitir lectura si el usuario está logueado en la red CIMCO
      allow read: if request.auth != null;
      
      // Permitir escritura para creación de viajes y chats
      // (Excepto wallets, que ya está blindado arriba)
      allow write: if request.auth != null;
    }

    /**
     * 🔒 CIERRE DE SEGURIDAD (Zero-Trust)
     * Bloquea cualquier intento de acceso fuera del Path Sagrado del proyecto.
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}