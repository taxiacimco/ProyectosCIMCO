rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 🛡️ FUNCIONES DE GOBERNANZA Y AUTENTICACIÓN
    // ==========================================
    
    function usuarioAutenticado() {
      return request.auth != null;
    }

    function esUsuarioAnonimo() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function esAdmin() {
      return usuarioAutenticado() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.rol == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin')) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin' ||
           get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin'))
      );
    }

    // ==========================================
    // 🚀 REGLAS DE ACCESO PARA COLECCIONES CORE
    // ==========================================

    // 👥 COLECCIÓN DE USUARIOS / OPERADORES
    match /users/{userId} {
      allow read, write: if true;
      match /{document=**} { allow read, write: if true; }
    }

    match /usuarios/{userId} {
      allow read, write: if true;
      match /{document=**} { allow read, write: if true; }
    }

    // 🛵 NODO DE CONFIGURACIÓN Y VIAJES DE ARTIFACTS
    match /artifacts/taxiacimco-app/public/data/{collection}/{document=**} {
      allow read, write: if true;
    }

    // 💰 BILLETERAS Y FINANZAS
    match /wallets/{walletId} { allow read, write: if true; }
    match /historial_saldo/{id} { allow read, write: if true; }

    // ==========================================================
    // 🔥 ENTORNO DE SIMULACIÓN Y TELEMETRÍA (ABIERTO PARA EMULADOR LOCAL)
    // ==========================================================
    
    // El simulador escribe de forma directa en el nodo raíz de viajes
    match /viajes/{viajeId} {
      allow read, write: if true;
    }

    match /viajes/{document=**} {
      allow read, write: if true;
    }

    // Compatibilidad secundaria para el radar dinámico de conductores activos
    match /conductores_activos/{document=**} {
      allow read, write: if true;
    }

    match /conductores/{document=**} {
      allow read, write: if true;
    }

    // COMODÍN DE EMERGENCIA GLOBAL (Garantiza desacoplamiento completo en ambiente de desarrollo)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}