rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 💳 REGLA ESPECÍFICA PARA BILLETERAS (CIMCO WALLETS)
    // Permite leer y escribir solo si el usuario está autenticado
    match /artifacts/taxiacimco-app/public/data/wallets/{walletId} {
      allow read, write: if request.auth != null;
    }

    // 🛵 REGLA PARA VIAJES Y MENSAJES
    match /artifacts/taxiacimco-app/public/data/viajes/{viajeId} {
      allow read, write: if request.auth != null;
    }
    
    match /artifacts/taxiacimco-app/public/data/mensajes/{mensajeId} {
      allow read, write: if request.auth != null;
    }

    // 🔓 REGLA GLOBAL TEMPORAL (Para no bloquear otros módulos en desarrollo)
    match /{document=**} {
      allow read, write: if true; 
    }
  }
}