rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // FUNCIONES DE SEGURIDAD (EL MOTOR)
    // ==========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica si un conductor tiene saldo suficiente
    // Buscamos el balance en la ruta específica del usuario
    function hasEnoughCredit(appId, uid) {
      let walletPath = /databases/$(database)/documents/artifacts/$(appId)/users/$(uid)/wallet/balance;
      return exists(walletPath) && get(walletPath).data.saldo >= 0;
    }

    // ==========================================
    // REGLAS PARA LA ESTRUCTURA DE ARTEFACTOS
    // ==========================================

    match /artifacts/{appId} {
      
      // --- DATOS PÚBLICOS (SOS, VIAJES, ETC) ---
      match /public/data/{collectionName}/{docId} {
        
        // Reglas para SOS
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && (
          // Solo se permite actualizar para resolver o si se es Admin
          request.resource.data.estado == 'RESUELTO'
        );

        // Reglas para VIAJES (Aquí vive el bloqueo por deuda)
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && (
          // Si el estado cambia a 'aceptado', validamos crédito instantáneamente
          (request.resource.data.estado == 'aceptado') 
            ? hasEnoughCredit(appId, request.auth.uid) 
            : true
        );
      }

      // --- BILLETERAS (PRIVADAS) ---
      match /users/{userId}/wallet/balance {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        // BLOQUEO TOTAL: El cliente NUNCA modifica su saldo. Solo Admin SDK (Backend Java).
        allow write: if false; 
      }

      // --- PERFILES DE USUARIO ---
      match /users/{userId}/profile/data {
        allow read: if isAuthenticated();
        // El usuario puede crear su perfil, pero no cambiar campos sensibles como su ROL
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && request.auth.uid == userId 
                      && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'appId']);
      }

      // --- ESTADÍSTICAS GLOBALES ---
      match /public/data/admin_stats/{docId} {
        allow read: if isAuthenticated();
        allow write: if false; 
      }
    }

    // --- BLOQUEO POR DEFECTO ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}