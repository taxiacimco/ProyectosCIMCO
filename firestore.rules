// Versión Arquitectura: V11.6 - Blindaje Perimetral de Bóvedas y Bloqueo de Superposición de Permisos
/**
 * Archivo: firestore.rules
 * Misión: Blindar la estructura de datos de TAXIA CIMCO.
 * Regla de Oro: Toda interacción operativa debe ocurrir bajo artifacts/taxiacimco-app/public/data/
 * FIX ARQUITECTURA: Se bloqueó la superposición del comodín {collection} para proteger wallets e historial_saldo.
 */

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🚀 REGLA: Permiso atómico para la creación del perfil en el registro
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * 💰 SECCIÓN: BILLETERAS (wallets)
     * Máxima seguridad: Solo el CEO (Admin) inyecta saldo.
     * Lectura permitida para el dueño o para el CEO.
     */
    match /artifacts/taxiacimco-app/public/data/wallets/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    /**
     * 📊 SECCIÓN: AUDITORÍA FINANCIERA (historial_saldo)
     * Trazabilidad de inyecciones y débitos. Solo Admin inyecta, usuario solo lee sus movimientos.
     */
    match /artifacts/taxiacimco-app/public/data/historial_saldo/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    /**
     * 🛵 SECCIÓN: OPERATIVA (viajes, mensajes, conductores)
     * Permite la dinámica del negocio para usuarios autenticados.
     */
    match /artifacts/taxiacimco-app/public/data/{collection}/{document=**} {
      allow read: if request.auth != null;
      
      // ⚠️ GUARDA DE SEGURIDAD MAESTRA: El comodín NO puede escribir en tesorería.
      allow write: if request.auth != null 
                   && collection != 'wallets' 
                   && collection != 'historial_saldo';
    }
  }
}