// Versión Arquitectura: V9.2 - Optimización de Radar (Zero-Read Cost)
/**
 * ARCHIVO: firestore.rules
 * PROYECTO: TAXIA CIMCO
 * MISIÓN: Validar solvencia mediante Custom Claims para eliminar costos de lectura en GPS.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 1. FUNCIONES NUCLEARES (CORE)
    // ============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && 
        (request.auth.token.rol == role || request.auth.token.rol == role.upper());
    }

    /**
     * ✅ OPTIMIZACIÓN V9.2: Ya no usa get(). 
     * Lee el claim 'hasCredit' directamente del token JWT. Costo: 0.
     */
    function hasEnoughCredit() {
      return request.auth.token.hasCredit == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ============================================================
    // 2. REGLAS DE NEGOCIO (TAXIA CIMCO PATH)
    // ============================================================

    match /artifacts/taxiacimco-app/public/data {
      
      // --- C. COLECCIÓN DE USUARIOS (CONDUCTORES Y PASAJEROS) ---
      match /usuarios/{userId} {
        
        // 🔓 Lectura: Cualquier usuario autenticado puede ver la ubicación para el radar de 5km
        allow read: if isAuthenticated();

        // 🔒 Escritura: Solo el dueño del perfil
        allow create: if isAuthenticated() && isOwner(userId);
        
        allow update: if isAuthenticated() && isOwner(userId)
          // 🛑 DEFENSA ATÓMICA: Prohibido alterar campos financieros o de rango desde el cliente
          && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['saldoWallet', 'rol', 'acceso_total', 'wallet_balance'])
          
          // 🛰️ VALIDACIÓN GPS SENTINEL:
          // El conductor solo puede actualizar su GPS si su TOKEN dice que tiene crédito
          && (
            (request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastLocation', 'lastActive']))
            ? hasEnoughCredit()
            : true
          );
      }

      // --- E. COLECCIÓN DE TRANSACCIONES (BILLETERA) ---
      match /transacciones/{txId} {
        // Solo el dueño puede ver su historial de dinero
        allow list: if isAuthenticated() && request.auth.uid == resource.data.targetUid;
        allow get: if isAuthenticated() && request.auth.uid == resource.data.targetUid;
        
        // Integridad Financiera: Nadie escribe transacciones desde el Frontend
        allow write: if false; 
      }

      // --- D. COLECCIÓN DE VIAJES (RIDES) ---
      match /rides/{rideId} {
        allow read: if isAuthenticated();
        allow create: if hasRole('pasajero') || hasRole('despachador');
        
        allow update: if isAuthenticated() && (
          // Si el viaje es aceptado por un conductor, verificamos su solvencia vía Token
          !(request.resource.data.status in ['aceptado', 'accepted']) || (
            (hasRole('mototaxi') || hasRole('conductor')) && hasEnoughCredit()
          )
        ) 
        // Proteger la tarifa de alteraciones externas
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['tarifa', 'comisionAplicada']);
      }
    }

    // ============================================================
    // 3. BLOQUEO POR DEFECTO (ZERO TRUST)
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}