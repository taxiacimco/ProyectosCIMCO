{
  "compilerOptions": {
    /* ===== CONFIGURACIÓN GENERAL ===== */
    "target": "ES2020",
    "module": "node16", /* CORREGIDO: Soporte para import.meta.url */
    "lib": ["ES2020"],
    "moduleResolution": "node16", /* CORREGIDO: Resolución de módulos moderna */
    "outDir": "./functions/lib", 
    "rootDir": "./functions/src", 

    /* ===== COMPATIBILIDAD Y RENDIMIENTO ===== */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* ===== SEGURIDAD Y CALIDAD ===== */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false, /* MODIFICADO: Ignora variables no usadas para permitir la compilación */
    "noUnusedParameters": false, /* MODIFICADO: Ignora parámetros no usadas para permitir la compilación */
    "noFallthroughCasesInSwitch": true,

    /* ===== DEBUG Y FUENTES ===== */
    "sourceMap": true,
    "removeComments": false
  },
  "include": [
    "functions/src/**/*.ts"
, "functions/src/middleware/role.guard.js", "functions/src/middleware/permission.guard.js", "functions/src/middleware/error-handler.js", "functions/src/middleware/auth.guard.js", "functions/src/middleware/async-handler.js", "functions/src/controllers/trip.controller.js", "functions/src/controllers/rides.controller.js", "functions/src/controllers/password.controller.js", "functions/src/controllers/drivers.controller.js", "functions/src/controllers/despatch.controller.js", "functions/src/controllers/auth.controller.js", "functions/src/controllers/admin.controller.js", "functions/src/routes/trip.routes.js", "functions/src/routes/rides.routes.js", "functions/src/routes/drivers.routes.js", "functions/src/routes/despatch.routes.js", "functions/src/routes/auth.routes.js", "functions/src/routes/admin.routes.js", "functions/src/index.js", "functions/src/server.js", "functions/src/index.js", "functions/src/index.js", "functions/src/routes/index.js", "functions/src/email/password-reset.template.js", "functions/src/email/email.service.js", "functions/src/config/roles.js", "functions/src/config/firebase.config.js", "functions/src/config/env.js", "functions/src/config/app.roles.js", "functions/src/config/env/index.js", "functions/src/config/env/env.schema.js", "functions/src/config/env/env.loader.js", "functions/src/config/env/env.config.js", "functions/src/firebase-init.js", "functions/src/firebase-admin.js", "functions/src/utils/responses.js", "functions/src/utils/jwt.js", "functions/src/utils/http-response.js", "functions/src/utils/auth-guard.js", "functions/src/services/utils.service.js", "functions/src/services/user.service.js", "functions/src/services/rides.service.js", "functions/src/services/rbac.service.js", "functions/src/services/driver.service.js", "functions/src/services/despatch.service.js", "functions/src/services/analytics.service.js", "functions/src/services/admin.service.js"  ],
