{
  "name": "taxia-cimco-backend",
  "version": "1.1.1",
  "type": "module",
  "description": "Cloud Functions for Firebase - Arquitectura Modular",
  "main": "src/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,auth,pubsub",
    "shell": "firebase functions:shell",
    "start": "npm run serve",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "dev": "node --watch src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rimraf node_modules"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "helmet": "^8.1.0"
  }
}
