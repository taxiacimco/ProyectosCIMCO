@BASE_URL = http://127.0.0.1:5001/pelagic-chalice-467818-e1/us-central1/api
@API_KEY = {{FIREBASE_API_KEY}}
@TOKEN = token_de_autenticacion_si_requieres

####################################################
### 🧠 TAXI A CIMCO - API TEST REQUESTS
### Ejecuta cada bloque con la extensión "REST Client"
####################################################

### 1️⃣ Health Check (verificar conexión)
GET {{BASE_URL}}/
Accept: text/plain

### 2️⃣ Registrar Pasajero
POST {{BASE_URL}}/registrarPasajero
Content-Type: application/json

{
  "email": "pasajero1@cimco.com",
  "nombre": "Juan Pasajero",
  "telefono": "3001234567",
  "direccion_recogida": "Plaza Central, La Jagua"
}

### 3️⃣ Registrar Conductor
POST {{BASE_URL}}/registrarConductor
Content-Type: application/json

{
  "email": "conductor1@cimco.com",
  "nombre": "Pedro Conductor",
  "password": "cimco123",
  "telefono": "3019876543",
  "cedula": "1234567890",
  "tipoVehiculo": "Mototaxi",
  "placa": "ABC123",
  "numeroInterno": "45",
  "cooperativa": "CIMCO Jagua"
}

### 4️⃣ Solicitar Servicio
# ⚠️ Copia aquí el ID real del pasajero desde Firestore:
@pasajeroId = REEMPLAZA_AQUI_EL_ID_REAL

POST {{BASE_URL}}/solicitarServicio
Content-Type: application/json

{
  "pasajeroId": "{{pasajeroId}}",
  "origen": "Plaza Central, La Jagua",
  "destino": "Hospital Local",
  "tipoServicio": "Mototaxi Express"
}

### 5️⃣ Listar Servicios
GET {{BASE_URL}}/listarServicios
Accept: application/json

####################################################
### 🔹 WHATSAPP CLOUD API (ENVÍO DE MENSAJES)
####################################################

POST {{BASE_URL}}/enviarMensajeWhatsapp
Content-Type: application/json

{
  "telefono": "573001234567",
  "mensaje": "🚖 Hola, tu mototaxi está en camino. Gracias por usar TaxiACimco."
}

####################################################
### 🔹 GOOGLE MAPS API (DISTANCIA ENTRE DOS PUNTOS)
####################################################

POST {{BASE_URL}}/calcularDistancia
Content-Type: application/json

{
  "origen": "La Jagua de Ibirico, Cesar",
  "destino": "El Paso, Cesar"
}

####################################################
### 🔹 GEMINI AI (RESPUESTA INTELIGENTE / CHATBOT)
####################################################

POST {{BASE_URL}}/geminiResponder
Content-Type: application/json

{
  "mensaje": "Hola Gemini, ¿qué tiempo estimado hay entre La Jagua y El Paso?"
}

####################################################
### 🧩 UTILIDAD: Obtener variables de entorno activas
####################################################

GET {{BASE_URL}}/debug/env
Accept: application/json

####################################################
### 6️⃣ Crear Solicitud de Servicio (Firestore)
####################################################

# ⚙️ Crea una solicitud de servicio real.
# 🔸 Puedes cambiar los valores según los usuarios registrados.
POST {{BASE_URL}}/servicio-solicitud
Content-Type: application/json

{
  "pasajero": {
    "id": "REEMPLAZA_AQUI_ID_PASAJERO",
    "nombre": "Juan Pasajero",
    "telefono": "3001234567"
  },
  "conductor": {
    "id": "REEMPLAZA_AQUI_ID_CONDUCTOR",
    "nombre": "Pedro Conductor",
    "placa": "ABC123",
    "telefono": "3019876543"
  },
  "ruta": {
    "origen": "Plaza Central, La Jagua",
    "destino": "Hospital Local, La Jagua",
    "distancia": "2.4 km",
    "tiempo_estimado": "5 minutos"
  },
  "estado": "pendiente",
  "metodo_pago": "efectivo",
  "costo_estimado": 4500,
  "fecha": "{{new Date().toISOString()}}"
}
