rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ REGLA DE DESARROLLO: Permite todo si el usuario está autenticado en emulador
    // Esto soluciona el error "false for get @ L69"
    match /{document=**} {
      allow read, write: if request.auth != null; 
    }

    // --- Tu lógica original de negocio (Se mantiene para cuando pases a producción) ---
    function isAuthenticated() {
      return request.auth != null;
    }

    match /artifacts/{appId}/public/data {
      match /conductores/{driverId} {
        allow read: if isAuthenticated();
        allow update: if isAuthenticated() && (
          request.auth.token.role == 'admin' || request.auth.uid == driverId
        );
      }
      
      match /viajes/{tripId} {
        allow create, read, update: if isAuthenticated();
      }
    }
  }
}