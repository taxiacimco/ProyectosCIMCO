{
  "name": "taxia-cimco-monorepo",
  "version": "1.1.0",
  "private": true,
  "description": "Workspace raíz para TAXIA CIMCO - Gestión Integral",
  "scripts": {
    "front:dev": "npm run dev --workspace=taxia-cimco-frontend",
    "front:build": "npm run build --workspace=taxia-cimco-frontend",
    "func:dev": "npm run serve --workspace=taxia-cimco-backend",
    "func:shell": "npm run shell --workspace=taxia-cimco-backend",
    "dev:all": "concurrently \"npm run front:dev\" \"npm run func:dev\"",
    "deploy:full": "npm run front:build && firebase deploy",
    "install:all": "npm install",
    "emuladores": "firebase emulators:start --import=./database --export-on-exit"
  },
  "workspaces": [
    "frontend",
    "functions"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0",
    "firebase-tools": "^13.0.0"
  }
}