// Versión Arquitectura: V7.8 - Actualización de Gitignore para Emuladores Locales
/**
 * .gitignore - TAXIA CIMCO
 * Misión: Protección de archivos sensibles, exclusión de dependencias y optimización de repositorio.
 */

============================================================
🛠️ BUILD (salida de TypeScript / Vite / React)
============================================================
lib/**/*.js
lib/**/*.js.map
dist/
build/
.cache/
out/

============================================================
📦 DEPENDENCIAS
============================================================
node_modules/
.pnp.*
.pnp.js

============================================================
⚠️ ARCHIVOS SENSIBLES Y DE ENTORNO
============================================================
# Archivos .env (variables privadas y locales)
.env
.env.local
.env.production
.env.*.local
functions/.env.local
functions/.env
functions/.env.production

# Permitimos el archivo de ejemplo para los desarrolladores
!functions/.env.example
!frontend/.env.example

# Credenciales privadas de Firebase o Google Cloud
serviceAccount.json
serviceAccountKey.json

# Claves de administrador específicas
functions/service-account/
functions/admin-sa.json

# Certificados o llaves
*.pem
*.key

============================================================
🔍 LOGS DE DEBUGGING (Firebase / Node)
============================================================
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
npm-debug.log
yarn-debug.log
yarn-error.log
*-debug.log
*.log

============================================================
📂 TIPADO ANTIGUO O AUTO-GENERADO
============================================================
typings/
*.tsbuildinfo

============================================================
💻 SISTEMAS / EDITORES
============================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

============================================================
📱 FRONTEND Y FIREBASE INTERNO
============================================================
*.local
*.cache
.firebaserc
.firebase/
_respaldos_backend/

============================================================
🧪 PRUEBAS Y SCRIPTS TEMPORALES
============================================================
tests/
pruebas/
*.test.js
*.spec.js

# ---------------------------------------------------------
# Exportaciones locales de emuladores de Firebase
# ---------------------------------------------------------
firebase-export-*/