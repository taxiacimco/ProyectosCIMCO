rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

// Helper function to check if the user is authenticated
function isAuthenticated() {
  return request.auth != null;
}

// Helper functions to check specific custom claims (roles)
// NOTE: These claims must be set on the user's Firebase Auth token by a Cloud Function or Admin SDK.
function isAdmin() {
  return isAuthenticated() && request.auth.token.admin == true;
}

function isCEO() {
  return isAuthenticated() && (isAdmin() || request.auth.token.ceo == true);
}

function isConductor() {
  return isAuthenticated() && (
    request.auth.token.mototaxi == true ||
    request.auth.token.motocarga == true ||
    request.auth.token.motoparrillero == true ||
    request.auth.token.interconductor == true
  );
}

function isPasajero() {
  return isAuthenticated() && (
    request.auth.token.pasajero == true ||
    request.auth.token.pasajero_corporativo == true
  );
}

function isDespachador() {
  return isAuthenticated() && request.auth.token.despachador == true;
}

// =========================================================================
// 1. Perfiles de Usuario (Collection: 'users' / 'conductores' / 'despachadores')
// =========================================================================

// Reglas para la colección principal de usuarios (auth perfiles)
match /users/{userId} {
  // Un usuario solo puede leer su propio perfil
  allow read: if isAuthenticated() && request.auth.uid == userId;
  // Un usuario solo puede actualizar su propio perfil (no crear)
  allow update: if isAuthenticated() && request.auth.uid == userId;
  // Los CEOs y Admins pueden listar o crear usuarios (esto se suele hacer en el backend, pero se permite la lectura general para seguridad)
  allow list, create: if isCEO();
}

// Reglas para Conductores (Mototaxi, Motocarga, etc.)
match /conductores/{conductorId} {
  // Todos los usuarios pueden leer la ubicación y estado de los conductores (para el mapa)
  allow read: if isAuthenticated();
  // Solo el conductor puede actualizar su propio estado/ubicación.
  allow update: if isConductor() && request.auth.uid == conductorId;
  // Los CEOs/Admins pueden crear, actualizar y eliminar (gestión)
  allow create, delete: if isCEO();
}

// Reglas para Despachadores
match /despachadores/{despachadorId} {
  // Solo el despachador o un CEO/Admin puede leer/escribir su propio perfil
  allow read: if isAuthenticated() && (request.auth.uid == despachadorId || isCEO());
  allow write: if isCEO();
}


// =========================================================================
// 2. Viajes y Servicios (Collection: 'viajes')
// =========================================================================

match /viajes/{viajeId} {
  // Permitir la creación del viaje (solicitud) a cualquier pasajero o despachador
  allow create: if isPasajero() || isDespachador();

  // Permitir la lectura a:
  allow read: if isCEO() || // CEO/Admin puede leer todos los viajes
                 (isPasajero() && resource.data.pasajeroId == request.auth.uid) || // Pasajero puede leer su propio viaje
                 (isConductor() && resource.data.conductorId == request.auth.uid) || // Conductor puede leer el viaje que le ha sido asignado
                 isDespachador(); // Despachador puede leer todos los viajes

  // Permitir la actualización a:
  allow update: if isCEO() || // CEO/Admin puede modificar cualquier cosa
                  (isPasajero() && resource.data.pasajeroId == request.auth.uid) || // Pasajero puede cancelar o actualizar un detalle (ej. destino)
                  (isConductor() && resource.data.conductorId == request.auth.uid) || // Conductor puede cambiar el estado (ej. Aceptar, Iniciar, Finalizar)
                  isDespachador(); // Despachador puede asignar/cancelar
}


// =========================================================================
// 3. Paneles de Monitoreo y Datos del Sistema
// =========================================================================

// Reglas estrictas para datos sensibles y configuración
match /configuracion/{docId} {
    allow read: if isAuthenticated(); // Todos pueden leer la configuración pública (ej. tarifas)
    allow write: if isCEO(); // Solo CEOs pueden escribir
}

// Colección para solicitudes o notificaciones internas (si aplica)
match /solicitudes/{solicitudId} {
  allow read, write: if isCEO() || isDespachador(); // Solo el personal autorizado
}

// =========================================================================
// 4. Regla de "Negación por Defecto"
// =========================================================================
// Bloquear todo acceso no definido explícitamente.
match /{document=**} {
  allow read, write: if false;
}


}
}